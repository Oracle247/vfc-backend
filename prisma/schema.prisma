// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  email       String    @unique
  phoneNumber String
  gender      Gender
  address     String
  dateOfBirth DateTime?
  password    String?

  // Campus-specific details
  matricNumber String? @unique // For students only
  department   String?
  level        String? // e.g. "100", "200", "300", "400", "Postgraduate"
  faculty      String?

  // Other identifiers
  nationality      String?
  stateOfOrigin    String?
  emergencyContact String?

  // Layered church journey
  churchStatus   ChurchStatus    @default(VISITOR)
  membershipType MembershipType?
  workerType     WorkerType?

  // System access role (separate from church journey)
  role UserRole @default(MEMBER)

  attendances  Attendance[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  departments  Department[] @relation("UserDepartments")
  headedDepartments Department[] @relation("DepartmentHead")
  assistantDepartments Department[] @relation("DepartmentAssistant")

  createdInvoices  Invoice[]        @relation("CreatedInvoices")
  paidInvoices     Invoice[]        @relation("PaidInvoices")
  approvedInvoices Invoice[]        @relation("ApprovedInvoices")
  recordedPayments InvoicePayment[] @relation("RecordedPayments")
  recordedIncomes  SessionIncome[]  @relation("RecordedIncomes")
  passwordInvites  InviteToken[]    @relation("UserInvites")
  createdInvites   InviteToken[]    @relation("CreatedInvites")
  deptLateUpdates  ServiceDayDepartmentLateTime[] @relation("DeptLateUpdates")
}

model AttendanceSession {
  id               String           @id @default(cuid())
  serviceName      String
  date             DateTime?
  startedAt        DateTime         @default(now())
  endedAt          DateTime?
  serviceDayId     String?
  serviceDay       ServiceDay?      @relation(fields: [serviceDayId], references: [id], onDelete: SetNull)
  specialProgramId String?
  specialProgram   SpecialProgram?  @relation(fields: [specialProgramId], references: [id], onDelete: SetNull)
  services         SessionService[]
  attendees        Attendance[]
  createdAt        DateTime         @default(now())

  @@index([serviceDayId])
  @@index([specialProgramId])
}

model ServiceDay {
  id            String                          @id @default(cuid())
  name          String
  weekday       Weekday
  services      ServiceDayService[]
  sessions      AttendanceSession[]
  deptLateTimes ServiceDayDepartmentLateTime[]
  createdAt     DateTime                        @default(now())
  updatedAt     DateTime                        @updatedAt
}

// Per-department late-coming override for a given service day. When a session
// for this ServiceDay is reported, workers in `department` are considered
// "late" if marked after `lateTime` (HH:mm, local). Falls back to the
// session-wide cutoff when no override exists.
model ServiceDayDepartmentLateTime {
  id           String     @id @default(cuid())
  serviceDayId String
  serviceDay   ServiceDay @relation(fields: [serviceDayId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  lateTime     String     // "HH:mm"
  updatedById  String?
  updatedBy    User?      @relation("DeptLateUpdates", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([serviceDayId, departmentId])
  @@index([serviceDayId])
  @@index([departmentId])
}

model ServiceDayService {
  id             String     @id @default(cuid())
  serviceDayId   String
  serviceDay     ServiceDay @relation(fields: [serviceDayId], references: [id], onDelete: Cascade)
  order          Int
  serviceTime    String     // "HH:mm"
  preServiceTime String?    // "HH:mm" or null
  closesAt       String?    // "HH:mm" or null

  @@unique([serviceDayId, order])
  @@index([serviceDayId])
}

model SpecialProgram {
  id        String                  @id @default(cuid())
  name      String
  date      DateTime?
  services  SpecialProgramService[]
  sessions  AttendanceSession[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model SpecialProgramService {
  id               String         @id @default(cuid())
  specialProgramId String
  specialProgram   SpecialProgram @relation(fields: [specialProgramId], references: [id], onDelete: Cascade)
  order            Int
  serviceTime      String         // "HH:mm"
  preServiceTime   String?        // "HH:mm" or null
  closesAt         String?        // "HH:mm" or null

  @@unique([specialProgramId, order])
  @@index([specialProgramId])
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model SessionService {
  id             String            @id @default(cuid())
  sessionId      String
  session        AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order          Int
  serviceTime    DateTime
  preServiceTime DateTime?
  closesAt       DateTime?
  incomes        SessionIncome[]

  @@unique([sessionId, order])
  @@index([sessionId])
}

model SessionIncome {
  id               String         @id @default(cuid())
  sessionServiceId String
  sessionService   SessionService @relation(fields: [sessionServiceId], references: [id], onDelete: Cascade)
  category         IncomeCategory
  method           PaymentMethod
  amount           Decimal        @db.Decimal(12, 2)
  recordedById     String?
  recordedBy       User?          @relation("RecordedIncomes", fields: [recordedById], references: [id], onDelete: SetNull)
  recordedAt       DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([sessionServiceId, category, method])
  @@index([sessionServiceId])
}

enum IncomeCategory {
  TITHE
  OFFERING
  SPECIAL_DONATION
}

enum PaymentMethod {
  CASH
  TRANSFER
}

model InviteToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserInvites", fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique
  createdById String?
  createdBy   User?     @relation("CreatedInvites", fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

model Attendance {
  id           String            @id @default(cuid())
  sessionId    String
  userId       String
  session      AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  markedAt     DateTime          @default(now())
  serviceOrder Int               @default(1)

  @@index([sessionId, serviceOrder])
}

model Department {
  id             String                          @id @default(uuid())
  name           String                          @unique
  description    String?
  headId         String?
  head           User?                           @relation("DepartmentHead", fields: [headId], references: [id])
  members        User[]                          @relation("UserDepartments")
  assistantHeads User[]                          @relation("DepartmentAssistant")
  lateTimes      ServiceDayDepartmentLateTime[]
}

model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique

  title       String
  description String?
  currency    String  @default("NGN")

  status InvoiceStatus @default(CREATED)

  totalAmount Float @default(0)

  createdById    String
  markedPaidById String?
  approvedById   String?

  receiptUrl String?

  paidAt     DateTime?
  approvedAt DateTime?

  createdBy    User? @relation("CreatedInvoices", fields: [createdById], references: [id])
  markedPaidBy User? @relation("PaidInvoices", fields: [markedPaidById], references: [id])
  approvedBy   User? @relation("ApprovedInvoices", fields: [approvedById], references: [id])

  departments InvoiceDepartment[]
  payments    InvoicePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceDepartment {
  id String @id @default(uuid())

  invoiceId      String
  departmentName String

  bankName      String
  accountName   String
  accountNumber String

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  items InvoiceItem[]

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model InvoiceItem {
  id          String @id @default(uuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  totalPrice  Float

  invoiceDepartmentId String
  invoiceDepartment   InvoiceDepartment @relation(fields: [invoiceDepartmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum Gender {
  MALE
  FEMALE
}

enum ChurchStatus {
  FIRST_TIMER
  VISITOR
  MEMBER
}

enum MembershipType {
  NON_WORKER
  WORKER
}

enum WorkerType {
  REGULAR
  EXECUTIVE
}

enum UserRole {
  MEMBER
  WORKER
  ADMIN
}

model InvoicePayment {
  id           String   @id @default(uuid())
  invoiceId    String
  amount       Float
  receiptUrl   String?
  note         String?
  recordedById String
  paidAt       DateTime @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User    @relation("RecordedPayments", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

enum InvoiceStatus {
  CREATED
  APPROVED
  PARTIALLY_PAID
  PAID
}

model ChurchSettings {
  id        String   @id @default("singleton")
  name      String
  logoUrl   String?
  address   String?
  updatedAt DateTime @updatedAt
}
